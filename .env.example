# MTA API Configuration
# Replace with your actual MTA API credentials
MTA_ALERTS_URL=https://api.new.mta.info/feed/json/
MTA_API_KEY=your_mta_api_key_here

# Path to stations CSV (for production, use full MTA GTFS stops.txt)
STATIONS_CSV_PATH=data/stations.csv

# Server configuration
FLASK_ENV=production
FLASK_DEBUG=False
